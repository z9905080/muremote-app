{
  "name": "muremote-pc",
  "version": "1.0.0",
  "description": "MuRemote PC Client - Remote control for MuMu Emulator",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/download-adb.js && node scripts/download-scrcpy.js && node scripts/ensure-wrtc.js",
    "prebuild": "node scripts/download-adb.js && node scripts/download-scrcpy.js && node scripts/ensure-wrtc.js",
    "build": "npm run prebuild && electron-builder --win"
  },
  "author": "MuRemote Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "24.13.3",
    "extract-zip": "^2.0.1"
  },
  "dependencies": {
    "bonjour": "^3.5.1",
    "electron-log": "^5.0.0",
    "ffmpeg-static": "^5.2.0",
    "iconv-lite": "^0.6.3",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "optionalDependencies": {
    "wrtc": "^0.4.7"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.10"
    }
  },
  "build": {
    "appId": "com.muremote.app",
    "productName": "MuRemote PC",
    "extraResources": [
      {
        "from": "resources/adb/",
        "to": "adb",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/scrcpy/",
        "to": "scrcpy",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "include": "build/installer.nsh"
    }
  }
}
